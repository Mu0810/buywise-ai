# ============================================================================
# BuyWise AI — Environment Variables
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.
# `.env` is read by both Next.js (runtime) and the Prisma CLI (migrations).
# ============================================================================

# Node environment: development | test | production
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# For local development, `docker compose up -d` starts Postgres on :5432.
# For production, point this at your Supabase / managed Postgres connection.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://buywise:buywise_dev_password@localhost:5432/buywise?schema=public"

# ---------------------------------------------------------------------------
# Redis (caching, rate limiting)
# `docker compose up -d` starts Redis on :6379.
# ---------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# ---------------------------------------------------------------------------
# Supabase (authentication)
# Create a project at https://supabase.com and copy these from
# Project Settings -> API. The anon key is safe to expose to the browser.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only. Never expose to the browser. Used for admin/service operations.
SUPABASE_SERVICE_ROLE_KEY=""

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# AI provider. AI_PROVIDER: auto (OpenAI when key set, else the rule-based
# engine) | openai | rule-based
# ---------------------------------------------------------------------------
AI_PROVIDER="auto"
OPENAI_API_KEY=""
# Optional. Point the OpenAI SDK at any OpenAI-compatible endpoint. Leave blank
# to use OpenAI directly. For free Groq inference use: https://api.groq.com/openai/v1
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-4o-mini"

# ---------------------------------------------------------------------------
# Stripe (Phase 4 — subscriptions). Create products/prices in the Stripe
# dashboard and paste the recurring price IDs below.
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_PREMIUM_MONTHLY=""
STRIPE_PRICE_PREMIUM_YEARLY=""
STRIPE_PRICE_FAMILY_MONTHLY=""
STRIPE_PRICE_FAMILY_YEARLY=""

# ---------------------------------------------------------------------------
# Cron secret for the price-drop check endpoint (/api/cron/check-alerts).
# Required in production; requests must send Authorization: Bearer <secret>.
# ---------------------------------------------------------------------------
CRON_SECRET=""
